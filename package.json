{
  "name": "dentcloud-hardware-bridge",
  "version": "1.0.0",
  "description": "DentCloud Hardware Bridge - Card Reader, EDC, Xray Uploader",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "dicom-parser": "^1.8.21",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "hex2imagebase64": "^1.0.0",
    "legacy-encoding": "^3.0.0",
    "node-fetch": "^2.7.0",
    "serialport": "^12.0.0",
    "sharp": "^0.33.5",
    "smartcard": "^3.7.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.dentcloud.hardware-bridge",
    "productName": "DentCloud Hardware Bridge",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.medical"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github"
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
